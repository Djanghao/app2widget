# OpenAI-compatible API configuration
# Copy this file to .env and fill in your values

# Your API key (required)
OPENAI_API_KEY=your-api-key-here

# API base URL (optional, defaults to OpenAI)
# For OpenAI: https://api.openai.com/v1
# For Claude via OpenAI-compatible endpoint: your-claude-endpoint
# For other compatible providers: their-endpoint-url
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name (optional, defaults to gpt-4)
# For OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# For Qwen: qwen3-vl-plus, qwen-turbo, etc.
# For other providers: their model names
OPENAI_MODEL=gpt-4
